        }
      ]
    }
  },
  {
    "object": "block",
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Si vous n'avez pas d'appareil physique sous la main, l'utilisation d'un émulateur Android (via Android Studio) ou iOS (via Simulator sur macOS) permet un débogage rapide et performant."
          }
        }
      ]
    }
  },
  {
    "object": "block",
    "type": "numbered_list_item",
    "numbered_list_item": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Démarrez votre émulateur à partir de votre IDE ou via la commande de gestion d'Android SDK."
          }
        }
      ]
    }
  },
  {
    "object": "block",
    "type": "numbered_list_item",
    "numbered_list_item": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Lancer la compilation de débogage :"
          }
        }
      ]
    }
  },
  {
    "object": "block",
    "type": "code",
    "code": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "   flutter run -d emulator"
          }
        }
      ],
      "language": "shell"
    }
  },
  {
    "object": "block",
    "type": "numbered_list_item",
    "numbered_list_item": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Le débogueur Flutter intègre également l'outil "
