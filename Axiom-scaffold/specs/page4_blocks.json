    "code": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "npx playwright test"
          }
        }
      ],
      "language": "shell"
    }
  },
  {
    "object": "block",
    "type": "heading_3",
    "heading_3": {
