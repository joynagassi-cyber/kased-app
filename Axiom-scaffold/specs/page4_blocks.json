    }
  },
  {
    "object": "block",
    "type": "numbered_list_item",
    "numbered_list_item": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Copiez l'intégralité de la "
          }
        },
        {
          "type": "text",
          "text": {
            "content": "Stack Trace rouge"
          },
          "annotations": {
            "bold": true
          }
        },
        {
          "type": "text",
          "text": {
            "content": " qui apparaît instantanément dans la console pour identifier la ligne exacte de code qui a généré l'exception."
          }
        }
      ]
