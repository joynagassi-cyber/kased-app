  {
    "object": "block",
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Pour valider que nos interfaces web ou nos API backend InsForge ne subissent aucune régression, nous utilisons "
