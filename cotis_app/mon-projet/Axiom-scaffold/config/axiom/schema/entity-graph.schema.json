{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Axiom Entity Graph Schema",
  "description": "JSON Schema pour le graphe unifié",
  "type": "object",
  "required": ["nodes", "edges", "metadata"],
  "properties": {
    "nodes": { "type": "array" },
    "edges": { "type": "array" },
    "metadata": { "type": "object" }
  }
}
