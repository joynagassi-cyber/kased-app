{
    "title": "MCP Shield Configuration",
    "description": "Configuration du proxy de sécurité pour les outils MCP",
    "version": "1.0.0",
    "security": {
        "enabled": true,
        "mode": "strict",
        "logLevel": "info"
    },
    "allowedTools": [
        "read_file",
        "write_file",
        "list_directory",
        "search_files",
        "grep_search",
        "file_search"
    ],
    "blockedTools": [
        "execute_command",
        "delete_file",
        "modify_permissions"
    ],
    "toolsRequiringApproval": [
        "write_file",
        "create_directory",
        "move_file",
        "copy_file"
    ],
    "pathRestrictions": {
        "blockedPaths": [
            "/etc",
            "/sys",
            "/proc",
            "/root",
            "~/.ssh",
            "~/.aws",
            "~/.config",
            "/var/log",
            "/boot"
        ],
        "allowedPaths": [
            "~/Documents/Project",
            "~/workspace",
            "/tmp/axiom-*"
        ],
        "blockedPatterns": [
            ".*\\.env$",
            ".*\\.key$",
            ".*\\.pem$",
            ".*id_rsa.*",
            ".*\\.secret$"
        ]
    },
    "fileRestrictions": {
        "maxFileSize": "10MB",
        "maxFileSizeBytes": 10485760,
        "allowedExtensions": [
            ".js",
            ".ts",
            ".jsx",
            ".tsx",
            ".py",
            ".java",
            ".go",
            ".rb",
            ".php",
            ".html",
            ".css",
            ".json",
            ".yaml",
            ".yml",
            ".md",
            ".txt"
        ],
        "blockedExtensions": [
            ".exe",
            ".dll",
            ".so",
            ".dylib",
            ".sh",
            ".bat",
            ".cmd",
            ".ps1"
        ]
    },
    "rateLimit": {
        "enabled": true,
        "requestsPerMinute": 60,
        "requestsPerHour": 1000,
        "requestsPerDay": 10000,
        "burstSize": 10
    },
    "validation": {
        "validateInputs": true,
        "validateOutputs": true,
        "sanitizeOutputs": true,
        "maxInputLength": 100000,
        "maxOutputLength": 1000000
    },
    "logging": {
        "logAllRequests": true,
        "logBlockedRequests": true,
        "logApprovedRequests": true,
        "logPath": "logs/mcp-shield.log",
        "logFormat": "json",
        "retentionDays": 90
    },
    "alerts": {
        "enabled": true,
        "alertOnBlocked": true,
        "alertOnSuspicious": true,
        "alertThreshold": 5,
        "alertChannels": [
            "slack",
            "email"
        ]
    },
    "secretDetection": {
        "enabled": true,
        "patterns": [
            "sk-[a-zA-Z0-9]{48}",
            "AKIA[0-9A-Z]{16}",
            "ghp_[a-zA-Z0-9]{36}",
            "-----BEGIN.*PRIVATE KEY-----"
        ],
        "action": "block"
    },
    "contentFiltering": {
        "enabled": true,
        "blockMaliciousPatterns": true,
        "blockSQLInjection": true,
        "blockXSS": true,
        "blockCommandInjection": true
    },
    "approvalWorkflow": {
        "enabled": true,
        "requireHumanApproval": true,
        "approvalTimeout": 300,
        "autoApproveAfterTimeout": false,
        "approvers": [
            "security-team",
            "tech-lead"
        ]
    },
    "monitoring": {
        "enabled": true,
        "metricsEnabled": true,
        "metricsInterval": 60,
        "healthCheckEnabled": true,
        "healthCheckInterval": 30
    }
}